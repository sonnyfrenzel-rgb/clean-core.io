{
  "name": "ai-studio-applet",
  "version": "1.7.2",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "eslint .",
    "clean": "next clean",
    "build:report": "node scripts/generate-report.js && node scripts/generate-whitepaper.js",
    "electron:dev": "concurrently \"npm run dev\" \"cross-env NODE_ENV=development electron .\"",
    "electron:pack": "next build && electron-builder --dir",
    "electron:dist": "next build && electron-builder"
  },

    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.11.0",
    "firebase-admin": "^14.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.553.0",
    "marked": "^13.0.3",
    "mermaid": "^11.15.0",
    "motion": "^12.23.24",
    "next": "15.5.14",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",

# GEMINI_API_KEY: Required for server-side Gemini AI API calls.
GEMINI_API_KEY=

# GAMMA_API_KEY: Optional alternate API key used for specific platform capabilities.
GAMMA_API_KEY=

# NEXT_PUBLIC_APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
NEXT_PUBLIC_APP_URL=

# S4_ENCRYPTION_KEY: 32-byte base64 key for AES-256-GCM encryption of S/4HANA credentials.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
S4_ENCRYPTION_KEY=

# S4_HOST_ALLOWLIST: Comma-separated host suffixes allowed for S/4HANA SSRF validation.
# Leave empty to allow all public hosts (blocklist-only mode).
# Example: .s4hana.cloud,.hana.ondemand.com,.sapcloud.cn,sandbox.api.sap.com
S4_HOST_ALLOWLIST=.s4hana.cloud,.hana.ondemand.com,.sapcloud.cn,sandbox.api.sap.com,.sap-api.com


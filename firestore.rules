rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin check uses ONLY the custom claim token. The Firestore doc
    // fallback was removed because (a) admin status is set via the
    // set-admin-claim API which writes the custom claim, and (b) the
    // Firestore get() caused evaluation errors in the emulator when the
    // user document didn't exist yet (e.g., during first-time create).
    function isAdmin() {
      return isAuthenticated() && request.auth.token.get('admin', false) == true;
    }

    // NOTE: getUserData() and getUserOrgId() were removed because they used
    // get() calls that caused evaluation errors in the Firebase Emulator.
    // Quota enforcement is handled server-side by reserveTransformationQuota().
    // OrgId isolation is handled server-side in API routes.

    function userClientCreateKeys() {
      return [
        'firstName', 'lastName', 'email',
        'tier', 'status',
        'transformationsUsed', 'transformationsLimit',
        'maxTeamMembers', 'orgId',
        'identityProvider', 'createdAt', 'authMethod', 'isAdmin',
        's4TenantAccessAllowed', 's4TenantAccessRequested', 'mfaEnabled'
      ];
    }

    function userClientUpdateKeys() {
      return [
        'firstName', 'lastName', 'theme', 'landingPageDefault',
        'backupEnabled', 'desktopChatbotEnabled', 'updatedAt'
      ];
    }

    // NOTE: projectAllowedKeys() and isValidProject() were removed.
    // Field validation is handled server-side in API routes.

    // Validate User entity
    function isValidUser(data) {
      return data.firstName is string && data.firstName.size() > 0 && data.firstName.size() < 100 &&
             data.lastName is string && data.lastName.size() > 0 && data.lastName.size() < 100 &&
             data.email is string && data.email.size() < 255 &&
             data.tier in ['basic', 'starter', 'premium', 'unlimited', 'enterprise', 'pilot', 'pilot_byok'] &&
             data.transformationsUsed is number &&
             data.transformationsLimit is number &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (userId == request.auth.uid || isAdmin()) &&
                    (
                      isAdmin() || 
                      (
                        request.resource.data.keys().hasOnly(userClientCreateKeys()) &&
                        request.resource.data.get('orgId', null) == null &&
                        request.resource.data.get('email', '') == request.auth.token.email &&
                        request.resource.data.get('tier', 'pilot') == 'pilot' &&
                        request.resource.data.get('status', 'pending') == 'pending' &&
                        request.resource.data.get('isAdmin', false) == false &&
                        request.resource.data.get('transformationsUsed', 0) == 0 &&
                        request.resource.data.get('transformationsLimit', 5) == 5 &&
                        request.resource.data.get('maxTeamMembers', 1) == 1 &&
                        request.resource.data.get('s4TenantAccessAllowed', false) == false &&
                        request.resource.data.get('s4TenantAccessRequested', false) == false &&
                        request.resource.data.get('mfaEnabled', false) == false
                      )
                    );
      allow update: if isAuthenticated() && (
                      isAdmin() ||
                      (
                        userId == request.auth.uid &&
                        request.resource.data.diff(resource.data).changedKeys().hasOnly(userClientUpdateKeys()) &&
                        request.resource.data.diff(resource.data).addedKeys().hasOnly(userClientUpdateKeys()) &&
                        request.resource.data.diff(resource.data).removedKeys().hasOnly([])
                      )
                    );
      allow delete: if isAdmin();
    }

    match /user_secrets/{userId}/{allPaths=**} {
      allow read, write: if false; // Block all client-side read/write access.
    }

    // Validate Project entity
    function isValidProject(data, isUpdate) {
      return (isUpdate || (data.name is string && data.name.size() > 0 && data.name.size() < 255)) &&
             (isUpdate || (data.status in ['uploaded', 'analyzed', 'designed', 'transformed', 'testing', 'documented', 'completed'])) &&
             (isUpdate || (data.userId is string && data.userId == request.auth.uid)) &&
             (isUpdate || (data.createdAt is timestamp)) &&
             (!('legacyCode' in data) || (data.legacyCode is string && data.legacyCode.size() < 1000000)) &&
             (!('analysis' in data) || (data.analysis is string && data.analysis.size() < 1000000)) &&
             (!('solutionDesign' in data) || (data.solutionDesign is string && data.solutionDesign.size() < 1000000)) &&
             (!('generatedCode' in data) || (data.generatedCode is string && data.generatedCode.size() < 1000000)) &&
             (!('documentation' in data) || (data.documentation is string && data.documentation.size() < 1000000)) &&
             (!('presentation' in data) || (data.presentation is string && data.presentation.size() < 1000000)) &&
             (!('testCases' in data) || (data.testCases is list && data.testCases.size() < 100)) &&
             (!('testSuite' in data) || (data.testSuite is map)) &&
             (!('exports' in data) || (data.exports is map)) &&
             (!('usageReport' in data) || (data.usageReport is map)) &&
             (!('nonFunctionalRequirements' in data) || (data.nonFunctionalRequirements is map));
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      // Quota enforcement and field validation are server-side
      allow create: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['name', 'status', 'userId', 'createdAt']) &&
                    request.resource.data.keys().hasOnly(['name', 'status', 'userId', 'createdAt', 'legacyCode', 'fromExample']) &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.status in ['uploaded', 'created'] &&
                    request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 255;
      // F-01: Owner may update their project, but userId and createdAt are immutable.
      // Field-level size validation is enforced by isValidProject().
      allow update: if isAuthenticated() && (
                    isAdmin() || (
                      resource.data.userId == request.auth.uid &&
                      // Strict allowlist of client-writable draft & interactive fields (Finding P1)
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'status', 'legacyCode', 's4Deployment', 'extensibilityRoute', 'solutionDesign',
                        'targetArchitecture', 'approvedByArchitect', 'architectJustifiedOverride', 'architectSignOffAt', 'approvedBy',
                        'generatedCode', 'documentation', 'businessDocumentation', 'presentation',
                        'testCases', 'testSuite', 'coverageEstimate', 'manualTestingRequirements',
                        'worklist', 'exports', 'updatedAt', 's4Environment',
                        'usageReport', 'nonFunctionalRequirements'
                      ])
                    )) && isValidProject(request.resource.data, true);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /projects/{projectId}/runs/{runId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow write: if false;
    }

    // Validate SupportTicket
    function isValidSupportTicket(data) {
      return data.userId == request.auth.uid &&
             data.subject is string && data.subject.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.status in ['open', 'in_progress', 'closed'] &&
             data.createdAt is timestamp;
    }

    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isAuthenticated() &&
                    isValidSupportTicket(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Validate FileEntry entity
    function isValidFileEntry(data, isUpdate) {
      return (isUpdate || (data.name is string && data.name.size() > 0 && data.name.size() < 255)) &&
             (isUpdate || (data.content is string && data.content.size() < 1000000)) &&
             (isUpdate || (data.userId is string && data.userId == request.auth.uid)) &&
             (isUpdate || (data.createdAt is timestamp));
    }

    match /files/{fileId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['name', 'content', 'userId', 'createdAt']) &&
                    isValidFileEntry(request.resource.data, false);
      allow update: if isAuthenticated() &&
                    (('userId' in resource.data && resource.data.userId == request.auth.uid) || isAdmin()) &&
                    isValidFileEntry(request.resource.data, true) &&
                    (!('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId) &&
                    (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if isAuthenticated() && (('userId' in resource.data && resource.data.userId == request.auth.uid) || isAdmin());
    }

    // Validate ABAPExample entity
    function isValidABAPExample(data, isUpdate) {
      return (isUpdate || (data.name is string && data.name.size() > 0 && data.name.size() < 255)) &&
             (isUpdate || (data.code is string && data.code.size() < 1000000)) &&
             (isUpdate || (data.userId is string && data.userId == request.auth.uid)) &&
             (isUpdate || (data.createdAt is timestamp));
    }

    match /abap_examples/{exampleId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['name', 'code', 'userId', 'createdAt']) &&
                    isValidABAPExample(request.resource.data, false);
      allow update: if isAuthenticated() &&
                    (('userId' in resource.data && resource.data.userId == request.auth.uid) || isAdmin()) &&
                    isValidABAPExample(request.resource.data, true) &&
                    (!('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId) &&
                    (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt);
    }

    match /registration_requests/{requestId} {
      allow read: if isAuthenticated() && (requestId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && requestId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /tenant_access_requests/{requestId} {
      allow read: if isAuthenticated() && (requestId == request.auth.uid || isAdmin());
      allow create: if (isAuthenticated() && requestId == request.auth.uid) || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // F-03: S/4HANA-Credentials: ausschließlich serverseitig (Admin SDK). Clients nie.
    match /s4_credentials/{uid} {
      allow read, write: if false;
    }

    // MFA Option B: MFA Secrets ausschließlich serverseitig (Admin SDK). Clients nie.
    match /mfa_secrets/{uid} {
      allow read, write: if false;
    }

    // F-08: MFA pending tokens: server-only via Admin SDK. Explicit deny for audit clarity.
    match /mfa_pending/{uid} {
      allow read, write: if false;
    }

    // Audit events: server-only via Admin SDK. No client access.
    match /audit_events/{eventId} {
      allow read, write: if false;
    }

    // User secrets (e.g. BYOK keys): server-only via Admin SDK. No client access.
    match /user_secrets/{uid}/{document=**} {
      allow read, write: if false;
    }

    match /rate_limits/{key} {
      allow read, write: if false;
    }
  }
}

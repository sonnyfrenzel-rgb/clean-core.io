{
  "appId": "io.clean-core.app",
  "productName": "Clean-Core",
  "copyright": "Copyright © 2026 Clean-Core.io",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.js",
    "preload.js",
    "package.json",
    "out/**/*",
    "public/**/*"
  ],
  "win": {
    "target": "nsis",
    "icon": "public/favicon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Clean-Core"
  },
  "mac": {
    "target": "dmg",
    "category": "public.app-category.developer-tools"
  },
  "dmg": {
    "background": null,
    "backgroundColor": "#090d16",
    "window": {
      "width": 540,
      "height": 380
    },
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Development"
  }
}
